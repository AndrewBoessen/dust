<?xml version="1.0" encoding="UTF-8"?>
<!--
  WinSW service wrapper configuration for the Dust daemon.

  Install with:
    dust-service.exe install
  Start with:
    dust-service.exe start
  Uninstall with:
    dust-service.exe uninstall

  WinSW: https://github.com/winsw/winsw
-->
<service>
  <id>dust</id>
  <name>Dust Daemon</name>
  <description>Dust Distributed File System Daemon</description>

  <executable>%BASE%\dust.bat</executable>
  <arguments>start</arguments>

  <startmode>Automatic</startmode>

  <env name="DUST_DATA_DIR" value="%LOCALAPPDATA%\Dust" />
  <env name="RELEASE_NODE" value="dust@127.0.0.1" />

  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>5</keepFiles>
  </log>

  <onfailure action="restart" delay="5 sec" />
  <onfailure action="restart" delay="10 sec" />
  <onfailure action="none" />

  <resetfailure>1 hour</resetfailure>
</service>
